# .gitattributes — harness-all global line ending policy
#
# Core principle: all shell scripts (.sh) must use LF line endings
# Reason: Git Bash (MINGW64) cannot execute CRLF scripts; it errors with:
#   \r: command not found
#   /bin/bash^M: bad interpreter
#
# Even when Windows users enable core.autocrlf=true,
# eol=lf in .gitattributes overrides local settings, ensuring the working tree checks out as LF

# Shell scripts — force LF (most critical)
*.sh text eol=lf

# Git hook scripts (no extension) — force LF
# Note: files under .git/hooks/ are not managed by .gitattributes,
# but source files under .harness/hooks/ are managed
.harness/hooks/* text eol=lf
.harness/hooks/guards/* text eol=lf

# General text files — force LF (required for cross-framework byte-equality checks in validate.ps1)
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.csv text eol=lf

# Web/code files — force LF
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.py text eol=lf

# Config files — force LF
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
.env.example text eol=lf

# Binary files — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
