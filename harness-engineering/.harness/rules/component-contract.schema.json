{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harness.local/schemas/component-contract.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "design_revision", "token_source", "components"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "design_revision": { "type": "string", "minLength": 1 },
    "token_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "pattern": "^(docs/design-system/|artifacts/)", "description": "Path to tokens.json. In engineering, tokens.json lives at docs/design-system/tokens.json. The artifacts/ prefix is retained for handoff-package-relative paths." },
        "sha256": { "type": "string", "pattern": "^([a-f0-9]{64}|<sha256>)$" },
        "provenance": { "type": "string", "enum": ["user-provided", "agent-inferred-from-prd", "handoff"], "description": "Origin of the tokens. 'agent-inferred-from-prd' is set when design-intake runs in PRD-only mode (no external design asset); downstream phases and verify use this to adjust expectations on visual fidelity." }
      }
    },
    "entities": {
      "type": "array",
      "description": "Data model entities surfaced from PRD (Phase 0) or user conversation (degraded mode). Consumed by Phase 2 data-layer to drive schema/ORM/migration design. Optional in family mode (Phase 2 can read PRD directly); required in standalone-fallback mode (no PM handoff).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["entity_id", "name", "fields"],
        "properties": {
          "entity_id": { "type": "string", "pattern": "^ENT-[A-Z0-9-]+$" },
          "name": { "type": "string", "minLength": 1 },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "type", "required"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "type": { "type": "string", "description": "Field type (string, number, boolean, date, enum, json, reference)" },
                "required": { "type": "boolean" },
                "unique": { "type": "boolean", "description": "Field must be unique (e.g., email, slug)" },
                "enum_values": { "type": "array", "items": { "type": "string" } },
                "default": {},
                "reference": { "type": "string", "description": "Referenced entity_id (for reference type fields)" }
              }
            },
            "minItems": 1
          },
          "relationships": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "target", "from_field"],
              "properties": {
                "type": { "enum": ["one-to-one", "one-to-many", "many-to-one", "many-to-many"] },
                "target": { "type": "string", "description": "Target entity_id" },
                "from_field": { "type": "string", "description": "Field on this entity that holds the reference" },
                "through": { "type": "string", "description": "Junction table/entity name (many-to-many only)" }
              }
            }
          },
          "ac_refs": {
            "type": "array",
            "items": { "type": "string" },
            "description": "AC-xxx IDs from PRD that this entity satisfies. Enables AC-to-entity traceability."
          }
        }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component_id", "name", "purpose", "token_refs", "properties", "states", "accessibility"],
        "properties": {
          "component_id": { "type": "string", "pattern": "^CMP-[A-Z0-9-]+$" },
          "name": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "token_refs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "properties": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "required"],
              "properties": {
                "type": { "enum": ["string", "boolean", "number", "enum", "slot", "collection", "object"] },
                "values": { "type": "array", "items": { "type": ["string", "number", "boolean"] }, "uniqueItems": true },
                "required": { "type": "boolean" },
                "default": {}
              }
            }
          },
          "states": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
          "used_by": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "accessibility": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
        }
      }
    }
  }
}

