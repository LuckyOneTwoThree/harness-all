# .gitattributes — harness-design 换行符策略
#
# 核心原则：所有 Shell 脚本（.sh）必须使用 LF 换行符
# 原因：Git Bash (MINGW64) 无法执行 CRLF 脚本

# Shell 脚本 — 强制 LF
*.sh text eol=lf

# Harness hooks — 强制 LF（防御性，未来引入 hooks 时不踩 CRLF 坑）
.harness/hooks/* text eol=lf
.harness/hooks/guards/* text eol=lf

# 通用文本 — 自动规范化
*.md text auto
*.yaml text auto
*.yml text auto
*.json text auto
*.toml text auto
*.txt text auto

# 代码文件 — 强制 LF
*.js text eol=lf
*.ts text eol=lf
*.py text eol=lf
*.css text eol=lf
*.html text eol=lf

# 配置文件 — 强制 LF
.gitignore text eol=lf
.gitattributes text eol=lf

# 二进制文件
*.png binary
*.jpg binary
*.pdf binary
