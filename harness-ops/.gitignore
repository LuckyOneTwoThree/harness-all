# harness-ops gitignore

# Ops sensitive files (never commit)
.env
.env.local
.env.production
.env.staging
*.pem
*.key
id_rsa
id_ed25519
kubeconfig
credentials.json
service-account*.json
*.tfvars
!*.tfvars.example

# Terraform state
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Ansible vault
*.vault

# Dependencies
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# Build artifacts
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Temporary files
.harness-ops-tmp-*/
*.tmp
*.bak

# Archives and logs
.harness/memory/archives/
*.log

# System files
.DS_Store
Thumbs.db
