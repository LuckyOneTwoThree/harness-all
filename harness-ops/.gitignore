# harness-ops gitignore

# 运维敏感文件（绝不提交）
.env
.env.local
.env.production
.env.staging
*.pem
*.key
id_rsa
id_ed25519
kubeconfig
credentials.json
service-account*.json
*.tfvars
!*.tfvars.example

# Terraform 状态
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Ansible vault
*.vault

# 依赖
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# 构建产物
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo

# 临时文件
.harness-ops-tmp-*/
*.tmp
*.bak

# 归档与日志
.harness/memory/archives/
*.log

# 系统文件
.DS_Store
Thumbs.db
