# 项目根 .gitignore — 敏感文件 + 常见忽略

# 敏感文件（禁止提交）
.env
.env.local
.env.production
.env.staging
*.pem
*.key
id_rsa
id_ed25519
credentials.json
service-account*.json

# 依赖
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# 构建产物
dist/
build/
.next/
.nuxt/
out/

# 日志
*.log
npm-debug.log*

# IDE
.vscode/
.idea/
*.swp
*.swo

# harness-pm 安装/运行残留
.workbuddy/
.harness-pm-tmp-*/

# PM 产出数据（机器消费 JSON，不提交）
output/

# 系统
.DS_Store
Thumbs.db
